# Optional: override cache.redis_url from configs/*.yaml when cache.backend is "redis".
# First non-empty wins: RELIABILITY_LAB_REDIS_URL, then REDIS_URL.
#
# In-process (no Docker):
# RELIABILITY_LAB_REDIS_URL=fakeredis://lab/0
#
# Real Redis (e.g. Docker Desktop + docker compose):
# REDIS_URL=redis://localhost:6379/0
